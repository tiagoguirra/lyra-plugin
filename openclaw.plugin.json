{
  "id": "lyra-plugin",
  "name": "Lyra Channel",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "wsPort": { "type": "number" },
      "authToken": { "type": "string" }
    }
  },
  "uiHints": {
    "wsPort": { "label": "WebSocket port", "placeholder": "8765" },
    "authToken": { "label": "Auth Token", "sensitive": true, "placeholder": "token secreto compartilhado com o cliente" }
  }
}
